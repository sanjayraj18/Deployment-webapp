generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id       String @id @default(uuid())
  name     String
  email    String
  password String
  deployments Deployment[]
}

model Deployment{
  id          String @id @default(uuid())
  github_url  String
  userId      String
  user        User @relation(fields: [userId], references: [id])
}
